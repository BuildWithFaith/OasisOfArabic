# App URLs
NEXT_PUBLIC_APP_URL=https://oasisofarabic.com
NEXT_PUBLIC_PRIMARY_DOMAIN=https://oasisofarabic.com

# Database (Neon PostgreSQL)
# Get this from your Neon console: https://console.neon.tech
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Authentication (Better Auth)
# Generate a secret securely, e.g. using `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_super_secret_string
BETTER_AUTH_URL=http://localhost:3000

# Payment Gateway (PayFast)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_SECURED_KEY=your_secured_key
# Production: https://ipg1.apps.net.pk/Ecommerce/api
# Sandbox: https://ipguat.apps.net.pk/Ecommerce/api
PAYFAST_BASE_URL=https://ipg1.apps.net.pk/Ecommerce/api

# Email / SMTP (Optional down the line, kept for structure)
SMTP_PASSWORD=your_smtp_password

# OpenAI (If still using agents for chat, etc.)
OPENAI_API_KEY=

# Meta Tracking (Analytics)
META_ACCESS_TOKEN=
NEXT_PUBLIC_META_DATASET_ID=